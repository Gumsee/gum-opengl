@PACKAGE_INIT@

include("@CMAKE_INSTALL_FULL_LIBDIR@/cmake/@CMAKE_PROJECT_NAME@/@CMAKE_PROJECT_NAME@Targets.cmake")

check_required_components(@CMAKE_PROJECT_NAME@)

set(GUMOPENGL_INCLUDE_DIRS   "@CMAKE_INSTALL_FULL_INCLUDEDIR@/@CMAKE_PROJECT_NAME@" )
find_library(GUMOPENGL_LIBRARIES NAMES @CMAKE_PROJECT_NAME@
    PATHS
    "/usr/lib"
    "/usr/local/lib"
    "@CMAKE_INSTALL_FULL_LIBDIR@"
)

set(GUMOPENGL_FOUND TRUE)
if(NOT GUMOPENGL_LIBRARIES)
    set(GUMOPENGL_FOUND FALSE)
endif()
